{
  "name": "@wiseaidev/lmm",
  "version": "0.1.7",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "lmm": "bin/lmm.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wiseaidotdev/lmm.git"
  },
  "homepage": "https://wiseai.dev",
  "bugs": {
    "url": "https://github.com/wiseaidotdev/lmm/issues"
  },
  "author": "Mahmoud Harmouch <oss@wiseai.dev>",
  "license": "MIT",
  "description": "A language agnostic framework for emulating reality: A pure Rust, training-free, equation-based intelligence.",
  "keywords": [
    "lmm",
    "ai",
    "machine-learning",
    "symbolic-math",
    "physics-simulation",
    "causal-reasoning",
    "rust",
    "wasm",
    "napi"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "bin/",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "napi": {
    "binaryName": "lmm",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --features node",
    "build:debug": "napi build --platform --features node",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  },
  "engines": {
    "node": ">= 22"
  },
  "optionalDependencies": {}
}
